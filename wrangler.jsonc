{
  "name": "pelcre",
  "main": "./src/worker.ts",
  "compatibility_date": "2026-07-08",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/sitemap.xml",
      "/",
      "/about",
      "/services",
      "/projects",
      "/projects/*",
      "/contact",
      "/privacy"
    ]
  }
}
